{
  "name": "@ferrum2d/topdown-shooter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pack:textures": "node ../../scripts/pack-textures.mjs --if-present",
    "dev": "pnpm --filter @ferrum2d/ferrum-web build && pnpm pack:textures && vite",
    "build": "pnpm pack:textures && vite build --base=./",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ferrum2d/ferrum-web": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
