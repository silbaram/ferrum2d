{
  "name": "@ferrum2d/placement-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ferrum2d/ferrum-web build && pnpm --filter @ferrum2d/authoring-viewer build && vite",
    "build": "pnpm --filter @ferrum2d/authoring-viewer build && vite build --base=./",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ferrum2d/authoring-viewer": "workspace:*",
    "@ferrum2d/ferrum-web": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
