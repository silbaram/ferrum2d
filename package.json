{
  "name": "ferrum2d",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "build:wasm": "wasm-pack build crates/ferrum-core --target web --out-dir ../../packages/ferrum-web/pkg",
    "build:web": "pnpm -r --filter './packages/*' --filter './examples/*' build",
    "build": "pnpm build:wasm && pnpm build:web",
    "test:rust": "cargo test --manifest-path crates/ferrum-core/Cargo.toml",
    "test:web": "pnpm --filter @ferrum2d/ferrum-web test",
    "validate:game-spec": "pnpm --filter @ferrum2d/ferrum-web build && node scripts/validate-game-spec.mjs examples/topdown-shooter/public/game.json",
    "create:game-variant": "pnpm --filter @ferrum2d/ferrum-web build && node scripts/create-game-variant.mjs",
    "check": "pnpm build && pnpm test",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm test:web && pnpm test:rust",
    "format": "pnpm -r --if-present format"
  }
}
