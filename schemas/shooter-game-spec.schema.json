{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ferrum2d.local/schemas/shooter-game-spec.schema.json",
  "title": "Ferrum2D Shooter Game Spec",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "world": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "player": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "enemies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed": { "type": "number", "exclusiveMinimum": 0 },
        "spawnInterval": { "type": "number", "exclusiveMinimum": 0 },
        "behavior": { "enum": ["chase", "drift", "static", "orbit"] },
        "spawnPattern": { "enum": ["edge", "corners", "center"] },
        "health": { "type": "number", "exclusiveMinimum": 0 },
        "scoreReward": { "type": "integer", "minimum": 1 },
        "orbit": { "$ref": "#/$defs/enemyOrbit" },
        "presets": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/enemyPreset" },
          "propertyNames": { "minLength": 1 }
        },
        "waves": {
          "type": "array",
          "items": { "$ref": "#/$defs/wave" }
        }
      }
    },
    "weapons": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bulletSpeed": { "type": "number", "exclusiveMinimum": 0 },
        "cooldown": { "type": "number", "exclusiveMinimum": 0 },
        "lifetime": { "type": "number", "exclusiveMinimum": 0 },
        "damage": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "prefabs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "player": { "$ref": "#/$defs/prefab" },
        "enemy": { "$ref": "#/$defs/prefab" },
        "bullet": { "$ref": "#/$defs/prefab" }
      }
    },
    "atlas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frames": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/atlasFrame" },
          "propertyNames": { "minLength": 1 }
        }
      }
    },
    "tilemap": { "$ref": "#/$defs/tilemap" },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preset": { "enum": ["follow", "dead-zone", "look-ahead", "shake"] },
        "deadZone": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": { "type": "number", "minimum": 0 },
            "height": { "type": "number", "minimum": 0 }
          }
        },
        "lookAhead": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "distance": { "type": "number", "minimum": 0 }
          }
        },
        "shake": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "amplitude": { "type": "number", "minimum": 0 },
            "frequency": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "physics": { "$ref": "#/$defs/physics" },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "masterVolume": { "type": "number", "minimum": 0 },
        "sfxVolume": { "type": "number", "minimum": 0 },
        "events": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "shoot": { "$ref": "#/$defs/audioEventPolicy" },
            "hit": { "$ref": "#/$defs/audioEventPolicy" },
            "gameOver": { "$ref": "#/$defs/audioEventPolicy" }
          }
        }
      }
    }
  },
  "$defs": {
    "enemyPreset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed": { "type": "number", "exclusiveMinimum": 0 },
        "behavior": { "enum": ["chase", "drift", "static", "orbit"] },
        "spawnPattern": { "enum": ["edge", "corners", "center"] },
        "health": { "type": "number", "exclusiveMinimum": 0 },
        "scoreReward": { "type": "integer", "minimum": 1 }
      }
    },
    "enemyOrbit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "radialBand": { "type": "number", "minimum": 0 }
      }
    },
    "wave": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enemy": { "type": "string", "minLength": 1 },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "spawnInterval": { "type": "number", "exclusiveMinimum": 0 },
        "enemyCount": { "type": "integer", "minimum": 1 },
        "spawnPattern": { "enum": ["edge", "corners", "center"] }
      }
    },
    "audioEventPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "volume": { "type": "number", "minimum": 0 },
        "pitch": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "tilemap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tileWidth": { "type": "number", "exclusiveMinimum": 0 },
        "tileHeight": { "type": "number", "exclusiveMinimum": 0 },
        "origin": { "$ref": "#/$defs/point" },
        "tiles": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/tileDefinition" },
          "propertyNames": { "pattern": "^[1-9][0-9]*$" }
        },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/tilemapLayer" }
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "tileDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame"],
      "properties": {
        "frame": { "type": "string", "minLength": 1 },
        "color": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "slope": { "$ref": "#/$defs/tileSlope" },
        "oneWayPlatform": { "type": "boolean" }
      },
      "not": {
        "required": ["slope", "oneWayPlatform"],
        "properties": {
          "oneWayPlatform": { "const": true }
        }
      }
    },
    "tileSlope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x0", "y0", "x1", "y1"],
      "properties": {
        "x0": { "type": "number", "minimum": 0, "maximum": 1 },
        "y0": { "type": "number", "minimum": 0, "maximum": 1 },
        "x1": { "type": "number", "minimum": 0, "maximum": 1 },
        "y1": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tilemapLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "rows", "data"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "tileWidth": { "type": "number", "exclusiveMinimum": 0 },
        "tileHeight": { "type": "number", "exclusiveMinimum": 0 },
        "origin": { "$ref": "#/$defs/point" },
        "collision": { "type": "boolean" },
        "collisionOnly": { "type": "boolean" },
        "data": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "collisionOnly": { "const": true } },
            "required": ["collisionOnly"]
          },
          "then": {
            "properties": { "collision": { "const": true } },
            "required": ["collision"]
          }
        }
      ]
    },
    "prefab": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "frame": { "type": "string", "minLength": 1 },
        "animation": { "$ref": "#/$defs/spriteAnimation" },
        "collider": { "$ref": "#/$defs/prefabCollider" }
      },
      "not": {
        "required": ["frame", "animation"]
      }
    },
    "prefabCollider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["aabb", "circle", "capsule", "orientedBox", "convexPolygon"] },
        "halfWidth": { "type": "number", "exclusiveMinimum": 0 },
        "halfHeight": { "type": "number", "exclusiveMinimum": 0 },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "start": { "$ref": "#/$defs/point" },
        "end": { "$ref": "#/$defs/point" },
        "rotationRadians": { "type": "number" },
        "vertices": {
          "type": "array",
          "minItems": 3,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/requiredPoint" }
        },
        "offset": { "$ref": "#/$defs/point" },
        "enabled": { "type": "boolean" },
        "trigger": { "type": "boolean" },
        "material": { "$ref": "#/$defs/physicsMaterial" }
      }
    },
    "requiredPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "physicsMaterial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restitution": { "type": "number", "minimum": 0 },
        "friction": { "type": "number", "minimum": 0 },
        "surfaceVelocity": { "$ref": "#/$defs/point" },
        "density": { "type": "number", "exclusiveMinimum": 0 },
        "contactBaumgarteBiasScale": { "type": "number", "minimum": 0 },
        "maxContactBaumgarteBiasVelocityScale": { "type": "number", "minimum": 0 },
        "contactPositionCorrectionScale": { "type": "number", "minimum": 0 },
        "contactPositionCorrectionSlopScale": { "type": "number", "minimum": 0 }
      }
    },
    "physics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["none", "arcade", "rigid"] },
        "gravity": { "$ref": "#/$defs/vector2" },
        "continuous": { "type": "boolean" },
        "solver": { "$ref": "#/$defs/physicsSolver" },
        "materials": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/physicsSpecMaterial" },
          "propertyNames": { "minLength": 1 }
        },
        "layers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/physicsLayer" },
          "propertyNames": { "minLength": 1 },
          "maxProperties": 31
        },
        "bodies": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/physicsBody" },
          "propertyNames": { "minLength": 1 }
        },
        "joints": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/physicsJoint" },
          "propertyNames": { "minLength": 1 }
        },
        "debug": {
          "oneOf": [
            { "type": "boolean" },
            { "$ref": "#/$defs/physicsDebug" }
          ]
        }
      }
    },
    "physicsSolver": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fixedTimestep": { "type": "boolean" },
        "stepSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "velocityIterations": { "type": "integer", "minimum": 0 },
        "positionIterations": { "type": "integer", "minimum": 0 },
        "sleep": { "type": "boolean" }
      }
    },
    "physicsSpecMaterial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "friction": { "type": "number", "minimum": 0 },
        "restitution": { "type": "number", "minimum": 0 },
        "density": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "physicsLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mask": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "physicsBody": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["static", "kinematic", "dynamic"] },
        "position": { "$ref": "#/$defs/vector2" },
        "rotationRadians": { "type": "number" },
        "velocity": { "$ref": "#/$defs/vector2" },
        "angularVelocityRadiansPerSecond": { "type": "number" },
        "mass": { "type": "number", "exclusiveMinimum": 0 },
        "inertia": { "type": "number", "exclusiveMinimum": 0 },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "collider": { "$ref": "#/$defs/physicsCollider" },
        "colliders": {
          "type": "array",
          "items": { "$ref": "#/$defs/physicsCollider" }
        },
        "gravityScale": { "type": "number" },
        "linearDamping": { "type": "number", "minimum": 0 },
        "angularDamping": { "type": "number", "minimum": 0 },
        "enabled": { "type": "boolean" },
        "canSleep": { "type": "boolean" }
      },
      "not": { "required": ["collider", "colliders"] }
    },
    "physicsCollider": {
      "oneOf": [
        { "$ref": "#/$defs/physicsBoxCollider" },
        { "$ref": "#/$defs/physicsCircleCollider" },
        { "$ref": "#/$defs/physicsCapsuleCollider" },
        { "$ref": "#/$defs/physicsOrientedBoxCollider" },
        { "$ref": "#/$defs/physicsConvexPolygonCollider" },
        { "$ref": "#/$defs/physicsEdgeCollider" },
        { "$ref": "#/$defs/physicsChainCollider" }
      ]
    },
    "physicsColliderBase": {
      "type": "object",
      "properties": {
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "physicsBoxCollider": {
      "allOf": [
        { "$ref": "#/$defs/physicsColliderBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["shape"],
          "properties": {
            "shape": { "enum": ["aabb", "box"] },
            "size": { "$ref": "#/$defs/positiveVector2" },
            "halfSize": { "$ref": "#/$defs/positiveVector2" },
            "offset": { "$ref": "#/$defs/vector2" },
            "material": { "type": "string", "minLength": 1 },
            "layer": { "type": "string", "minLength": 1 },
            "trigger": { "type": "boolean" },
            "enabled": { "type": "boolean" }
          },
          "oneOf": [
            { "required": ["size"] },
            { "required": ["halfSize"] }
          ]
        }
      ]
    },
    "physicsCircleCollider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "radius"],
      "properties": {
        "shape": { "const": "circle" },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "physicsCapsuleCollider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "start", "end", "radius"],
      "properties": {
        "shape": { "const": "capsule" },
        "start": { "$ref": "#/$defs/vector2" },
        "end": { "$ref": "#/$defs/vector2" },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "physicsOrientedBoxCollider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape"],
      "properties": {
        "shape": { "const": "orientedBox" },
        "size": { "$ref": "#/$defs/positiveVector2" },
        "halfSize": { "$ref": "#/$defs/positiveVector2" },
        "rotationRadians": { "type": "number" },
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      },
      "oneOf": [
        { "required": ["size"] },
        { "required": ["halfSize"] }
      ]
    },
    "physicsConvexPolygonCollider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "vertices"],
      "properties": {
        "shape": { "const": "convexPolygon" },
        "vertices": {
          "type": "array",
          "minItems": 3,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/vector2" }
        },
        "rotationRadians": { "type": "number" },
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "physicsEdgeCollider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "start", "end"],
      "properties": {
        "shape": { "const": "edge" },
        "start": { "$ref": "#/$defs/vector2" },
        "end": { "$ref": "#/$defs/vector2" },
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "physicsChainCollider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "vertices"],
      "properties": {
        "shape": { "const": "chain" },
        "vertices": {
          "type": "array",
          "minItems": 2,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/vector2" }
        },
        "loop": { "type": "boolean" },
        "offset": { "$ref": "#/$defs/vector2" },
        "material": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "minLength": 1 },
        "trigger": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "physicsJoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "bodyA", "bodyB"],
      "properties": {
        "type": { "enum": ["distance", "rope", "spring", "revolute", "prismatic", "gear"] },
        "bodyA": { "type": "string", "minLength": 1 },
        "bodyB": { "type": "string", "minLength": 1 },
        "anchor": { "$ref": "#/$defs/vector2" },
        "localAnchorA": { "$ref": "#/$defs/vector2" },
        "localAnchorB": { "$ref": "#/$defs/vector2" },
        "localAxisA": { "$ref": "#/$defs/vector2" },
        "restLength": { "type": "number", "minimum": 0 },
        "maxLength": { "type": "number", "minimum": 0 },
        "stiffness": { "type": "number", "minimum": 0, "maximum": 1 },
        "damping": { "type": "number", "minimum": 0, "maximum": 1 },
        "enabled": { "type": "boolean" },
        "limit": { "$ref": "#/$defs/physicsJointLimit" },
        "motor": { "$ref": "#/$defs/physicsJointMotor" },
        "ratio": { "type": "number" },
        "referenceAngle": { "type": "number" },
        "breakDistance": { "type": "number", "minimum": 0 },
        "breakAngle": { "type": "number", "minimum": 0 }
      }
    },
    "physicsJointLimit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "lower": { "type": "number" },
        "upper": { "type": "number" }
      }
    },
    "physicsJointMotor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "speed": { "type": "number" },
        "maxForce": { "type": "number", "minimum": 0 },
        "maxTorque": { "type": "number", "minimum": 0 }
      }
    },
    "physicsDebug": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colliders": { "type": "boolean" },
        "contacts": { "type": "boolean" },
        "manifolds": { "type": "boolean" },
        "broadphase": { "type": "boolean" },
        "joints": { "type": "boolean" },
        "sleeping": { "type": "boolean" },
        "layers": { "type": "boolean" },
        "ccd": { "type": "boolean" }
      }
    },
    "vector2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "positiveVector2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number", "exclusiveMinimum": 0 }
    },
    "atlasFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["texture", "uv", "size"],
      "properties": {
        "texture": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "uv": {
          "type": "object",
          "additionalProperties": false,
          "required": ["u0", "v0", "u1", "v1"],
          "properties": {
            "u0": { "type": "number", "minimum": 0, "maximum": 1 },
            "v0": { "type": "number", "minimum": 0, "maximum": 1 },
            "u1": { "type": "number", "minimum": 0, "maximum": 1 },
            "v1": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "size": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "spriteAnimation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "frames": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 },
        "atlas": { "$ref": "#/$defs/atlasAnimation" },
        "states": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "idle": { "$ref": "#/$defs/spriteAnimationState" },
            "move": { "$ref": "#/$defs/spriteAnimationState" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "frames": { "type": "integer", "minimum": 2 }
            },
            "required": ["frames"]
          },
          "then": {
            "required": ["fps"]
          }
        },
        {
          "if": {
            "required": ["states"]
          },
          "then": {
            "required": ["columns", "rows"]
          }
        },
        {
          "if": {
            "required": ["atlas"]
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["columns"] },
                { "required": ["rows"] },
                { "required": ["frames"] },
                { "required": ["fps"] },
                { "required": ["states"] }
              ]
            }
          }
        }
      ]
    },
    "atlasAnimation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idle"],
      "properties": {
        "idle": { "$ref": "#/$defs/atlasAnimationState" },
        "move": { "$ref": "#/$defs/atlasAnimationState" }
      }
    },
    "atlasAnimationState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frames", "fps"],
      "properties": {
        "frames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1 }
        },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "spriteAnimationState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frames", "fps"],
      "properties": {
        "row": { "type": "integer", "minimum": 0 },
        "frames": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
