{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ferrum2d.local/schemas/shooter-game-spec.schema.json",
  "title": "Ferrum2D Shooter Game Spec",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "world": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "player": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "enemies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed": { "type": "number", "exclusiveMinimum": 0 },
        "spawnInterval": { "type": "number", "exclusiveMinimum": 0 },
        "behavior": { "enum": ["chase", "drift", "static", "orbit"] },
        "spawnPattern": { "enum": ["edge", "corners", "center"] },
        "health": { "type": "number", "exclusiveMinimum": 0 },
        "scoreReward": { "type": "integer", "minimum": 1 },
        "orbit": { "$ref": "#/$defs/enemyOrbit" },
        "presets": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/enemyPreset" },
          "propertyNames": { "minLength": 1 }
        },
        "waves": {
          "type": "array",
          "items": { "$ref": "#/$defs/wave" }
        }
      }
    },
    "weapons": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bulletSpeed": { "type": "number", "exclusiveMinimum": 0 },
        "cooldown": { "type": "number", "exclusiveMinimum": 0 },
        "lifetime": { "type": "number", "exclusiveMinimum": 0 },
        "damage": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "prefabs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "player": { "$ref": "#/$defs/prefab" },
        "enemy": { "$ref": "#/$defs/prefab" },
        "bullet": { "$ref": "#/$defs/prefab" }
      }
    },
    "atlas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frames": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/atlasFrame" },
          "propertyNames": { "minLength": 1 }
        }
      }
    },
    "tilemap": { "$ref": "#/$defs/tilemap" },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preset": { "enum": ["follow", "dead-zone", "look-ahead", "shake"] },
        "deadZone": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": { "type": "number", "minimum": 0 },
            "height": { "type": "number", "minimum": 0 }
          }
        },
        "lookAhead": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "distance": { "type": "number", "minimum": 0 }
          }
        },
        "shake": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "amplitude": { "type": "number", "minimum": 0 },
            "frequency": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "masterVolume": { "type": "number", "minimum": 0 },
        "sfxVolume": { "type": "number", "minimum": 0 },
        "events": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "shoot": { "$ref": "#/$defs/audioEventPolicy" },
            "hit": { "$ref": "#/$defs/audioEventPolicy" },
            "gameOver": { "$ref": "#/$defs/audioEventPolicy" }
          }
        }
      }
    }
  },
  "$defs": {
    "enemyPreset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed": { "type": "number", "exclusiveMinimum": 0 },
        "behavior": { "enum": ["chase", "drift", "static", "orbit"] },
        "spawnPattern": { "enum": ["edge", "corners", "center"] },
        "health": { "type": "number", "exclusiveMinimum": 0 },
        "scoreReward": { "type": "integer", "minimum": 1 }
      }
    },
    "enemyOrbit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "radialBand": { "type": "number", "minimum": 0 }
      }
    },
    "wave": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enemy": { "type": "string", "minLength": 1 },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "spawnInterval": { "type": "number", "exclusiveMinimum": 0 },
        "enemyCount": { "type": "integer", "minimum": 1 },
        "spawnPattern": { "enum": ["edge", "corners", "center"] }
      }
    },
    "audioEventPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "volume": { "type": "number", "minimum": 0 },
        "pitch": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "tilemap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tileWidth": { "type": "number", "exclusiveMinimum": 0 },
        "tileHeight": { "type": "number", "exclusiveMinimum": 0 },
        "origin": { "$ref": "#/$defs/point" },
        "tiles": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/tileDefinition" },
          "propertyNames": { "pattern": "^[1-9][0-9]*$" }
        },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/tilemapLayer" }
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "tileDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame"],
      "properties": {
        "frame": { "type": "string", "minLength": 1 },
        "color": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "slope": { "$ref": "#/$defs/tileSlope" },
        "oneWayPlatform": { "type": "boolean" }
      },
      "not": {
        "required": ["slope", "oneWayPlatform"],
        "properties": {
          "oneWayPlatform": { "const": true }
        }
      }
    },
    "tileSlope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x0", "y0", "x1", "y1"],
      "properties": {
        "x0": { "type": "number", "minimum": 0, "maximum": 1 },
        "y0": { "type": "number", "minimum": 0, "maximum": 1 },
        "x1": { "type": "number", "minimum": 0, "maximum": 1 },
        "y1": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tilemapLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "rows", "data"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "tileWidth": { "type": "number", "exclusiveMinimum": 0 },
        "tileHeight": { "type": "number", "exclusiveMinimum": 0 },
        "origin": { "$ref": "#/$defs/point" },
        "collision": { "type": "boolean" },
        "collisionOnly": { "type": "boolean" },
        "data": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "collisionOnly": { "const": true } },
            "required": ["collisionOnly"]
          },
          "then": {
            "properties": { "collision": { "const": true } },
            "required": ["collision"]
          }
        }
      ]
    },
    "prefab": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "frame": { "type": "string", "minLength": 1 },
        "animation": { "$ref": "#/$defs/spriteAnimation" },
        "collider": { "$ref": "#/$defs/prefabCollider" }
      },
      "not": {
        "required": ["frame", "animation"]
      }
    },
    "prefabCollider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["aabb", "circle", "capsule", "orientedBox", "convexPolygon"] },
        "halfWidth": { "type": "number", "exclusiveMinimum": 0 },
        "halfHeight": { "type": "number", "exclusiveMinimum": 0 },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "start": { "$ref": "#/$defs/point" },
        "end": { "$ref": "#/$defs/point" },
        "rotationRadians": { "type": "number" },
        "vertices": {
          "type": "array",
          "minItems": 3,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/requiredPoint" }
        },
        "offset": { "$ref": "#/$defs/point" },
        "enabled": { "type": "boolean" },
        "trigger": { "type": "boolean" },
        "material": { "$ref": "#/$defs/physicsMaterial" }
      }
    },
    "requiredPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "physicsMaterial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restitution": { "type": "number", "minimum": 0 },
        "friction": { "type": "number", "minimum": 0 },
        "surfaceVelocity": { "$ref": "#/$defs/point" },
        "density": { "type": "number", "exclusiveMinimum": 0 },
        "contactBaumgarteBiasScale": { "type": "number", "minimum": 0 },
        "maxContactBaumgarteBiasVelocityScale": { "type": "number", "minimum": 0 },
        "contactPositionCorrectionScale": { "type": "number", "minimum": 0 },
        "contactPositionCorrectionSlopScale": { "type": "number", "minimum": 0 }
      }
    },
    "atlasFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["texture", "uv", "size"],
      "properties": {
        "texture": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "uv": {
          "type": "object",
          "additionalProperties": false,
          "required": ["u0", "v0", "u1", "v1"],
          "properties": {
            "u0": { "type": "number", "minimum": 0, "maximum": 1 },
            "v0": { "type": "number", "minimum": 0, "maximum": 1 },
            "u1": { "type": "number", "minimum": 0, "maximum": 1 },
            "v1": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "size": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "spriteAnimation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "frames": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 },
        "atlas": { "$ref": "#/$defs/atlasAnimation" },
        "states": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "idle": { "$ref": "#/$defs/spriteAnimationState" },
            "move": { "$ref": "#/$defs/spriteAnimationState" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "frames": { "type": "integer", "minimum": 2 }
            },
            "required": ["frames"]
          },
          "then": {
            "required": ["fps"]
          }
        },
        {
          "if": {
            "required": ["states"]
          },
          "then": {
            "required": ["columns", "rows"]
          }
        },
        {
          "if": {
            "required": ["atlas"]
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["columns"] },
                { "required": ["rows"] },
                { "required": ["frames"] },
                { "required": ["fps"] },
                { "required": ["states"] }
              ]
            }
          }
        }
      ]
    },
    "atlasAnimation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idle"],
      "properties": {
        "idle": { "$ref": "#/$defs/atlasAnimationState" },
        "move": { "$ref": "#/$defs/atlasAnimationState" }
      }
    },
    "atlasAnimationState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frames", "fps"],
      "properties": {
        "frames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1 }
        },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "spriteAnimationState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frames", "fps"],
      "properties": {
        "row": { "type": "integer", "minimum": 0 },
        "frames": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
