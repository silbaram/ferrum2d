{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://ferrum2d.dev/schemas/gameplay-authoring-dry-run-report.schema.json",
  "title": "Ferrum2D Gameplay Authoring Dry-run Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "format",
    "version",
    "ok",
    "gameplayAuthoringDryRun"
  ],
  "properties": {
    "format": {
      "const": "ferrum2d.gameplay-authoring.dry-run-report"
    },
    "version": {
      "const": 1
    },
    "ok": {
      "type": "boolean"
    },
    "gameplayAuthoringDryRun": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "variantPath",
        "diagnostics",
        "reports"
      ],
      "properties": {
        "variantPath": {
          "type": "string",
          "minLength": 1
        },
        "baseGameSpecPath": {
          "type": "string",
          "minLength": 1
        },
        "replayManifestPath": {
          "type": "string",
          "minLength": 1
        },
        "commandCount": {
          "type": "integer",
          "minimum": 1
        },
        "instanceCount": {
          "type": "integer",
          "minimum": 1
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/diagnostic"
          }
        },
        "reports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/machineActionableReport"
          }
        },
        "replay": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "replayManifestPath",
            "linked"
          ],
          "properties": {
            "replayManifestPath": {
              "type": "string",
              "minLength": 1
            },
            "linked": {
              "type": "boolean"
            },
            "scenario": {
              "type": "string",
              "minLength": 1
            },
            "replayHash": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}$"
            },
            "fixtureIndex": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "linked"
              ],
              "properties": {
                "linked": {
                  "type": "boolean"
                },
                "fixtureIndexPath": {
                  "type": "string",
                  "minLength": 1
                },
                "coverageTagDefinitionsPath": {
                  "type": "string",
                  "minLength": 1
                },
                "coverageTags": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "coverageTagDefinitions": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/diagnostic"
      }
    },
    "reports": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/machineActionableReport"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/errorSummary"
      }
    }
  },
  "definitions": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "machineActionableReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind",
        "code",
        "path",
        "message",
        "suggestion"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "suggestion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "errorSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "message"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
