{
  "name": "@ferrum2d/ferrum-web",
  "version": "0.1.0",
  "private": true,
  "description": "Ferrum2D browser runtime and WebGL2 platform layer",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "pkg/ferrum_core.js",
    "pkg/ferrum_core.d.ts",
    "pkg/ferrum_core_bg.wasm",
    "pkg/ferrum_core_bg.wasm.d.ts",
    "pkg/package.json"
  ],
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:dist-test": "node -e \"require('node:fs').rmSync('dist-test', { recursive: true, force: true })\"",
    "build": "pnpm run clean:dist && tsc -p tsconfig.json && node ../../scripts/fix-dist-esm-extensions.mjs dist",
    "check:package": "node ../../scripts/check-package-files.mjs",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "pnpm run build && pnpm run clean:dist-test && tsc -p tsconfig.test.json && node ../../scripts/fix-dist-esm-extensions.mjs dist-test && node --test dist-test/test/*.test.js"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
